  33:heartrate.c   **** static const uint16_t FIRCoeffs[12] = {172, 321, 579, 927, 1360, 1858, 2390, 2916, 3391, 3768, 4012
  34:heartrate.c   **** 
  35:heartrate.c   **** //  Heart Rate Monitor functions takes a sample value and the sample number
  36:heartrate.c   **** //  Returns true if a beat is detected
  37:heartrate.c   **** //  A running average of four samples is recommended for display on the screen.
  38:heartrate.c   **** bool checkForBeat(int32_t sample)
  39:heartrate.c   **** {
  40:heartrate.c   ****   bool beatDetected = false;
  41:heartrate.c   **** 
  42:heartrate.c   ****   //  Save current state
  43:heartrate.c   ****   IR_AC_Signal_Previous = IR_AC_Signal_Current;
  44:heartrate.c   **** 
  45:heartrate.c   ****   //  Process next data sample
  46:heartrate.c   ****   IR_Average_Estimated = averageDCEstimator(&ir_avg_reg, sample);
  47:heartrate.c   ****   IR_AC_Signal_Current = lowPassFIRFilter(sample - IR_Average_Estimated);
  48:heartrate.c   **** 
  49:heartrate.c   ****   //  Detect positive zero crossing (rising edge)
  50:heartrate.c   ****   if ((IR_AC_Signal_Previous < 0) && (IR_AC_Signal_Current >= 0))
  51:heartrate.c   ****   {
  52:heartrate.c   ****     IR_AC_Max = IR_AC_Signal_max; //Adjust our AC max and min
  53:heartrate.c   ****     IR_AC_Min = IR_AC_Signal_min;
  54:heartrate.c   **** 
  55:heartrate.c   ****     positiveEdge = 1;
  56:heartrate.c   ****     negativeEdge = 0;
  57:heartrate.c   ****     IR_AC_Signal_max = 0;
  58:heartrate.c   **** 
  59:heartrate.c   ****     //if ((IR_AC_Max - IR_AC_Min) > 100 && (IR_AC_Max - IR_AC_Min) < 1000)
  60:heartrate.c   ****     if ((IR_AC_Max - IR_AC_Min) > 20 && (IR_AC_Max - IR_AC_Min) < 1000)
  61:heartrate.c   ****     {
  62:heartrate.c   ****       //Heart beat!!!
  63:heartrate.c   ****       beatDetected = true;
  64:heartrate.c   ****     }
  65:heartrate.c   ****   }
  66:heartrate.c   **** 
  67:heartrate.c   ****   //  Detect negative zero crossing (falling edge)
  68:heartrate.c   ****   if ((IR_AC_Signal_Previous > 0) && (IR_AC_Signal_Current <= 0))
  69:heartrate.c   ****   {
  70:heartrate.c   ****     positiveEdge = 0;
  71:heartrate.c   ****     negativeEdge = 1;
  72:heartrate.c   ****     IR_AC_Signal_min = 0;
  73:heartrate.c   ****   }
  74:heartrate.c   **** 
  75:heartrate.c   ****   //  Find Maximum value in positive cycle
  76:heartrate.c   ****   if (positiveEdge && (IR_AC_Signal_Current > IR_AC_Signal_Previous))
  77:heartrate.c   ****   {
  78:heartrate.c   ****     IR_AC_Signal_max = IR_AC_Signal_Current;
  79:heartrate.c   ****   }
  80:heartrate.c   **** 
  81:heartrate.c   ****   //  Find Minimum value in negative cycle
  82:heartrate.c   ****   if (negativeEdge && (IR_AC_Signal_Current < IR_AC_Signal_Previous))
  83:heartrate.c   ****   {
  84:heartrate.c   ****     IR_AC_Signal_min = IR_AC_Signal_Current;
  85:heartrate.c   ****   }
  86:heartrate.c   ****   
  87:heartrate.c   ****   return(beatDetected);
ARM GAS  C:\Users\joshw\AppData\Local\Temp\cc8bI6We.s 			page 3


  88:heartrate.c   **** }
