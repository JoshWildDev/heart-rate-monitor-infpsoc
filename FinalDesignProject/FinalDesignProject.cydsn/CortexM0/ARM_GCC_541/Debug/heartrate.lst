  38:heartrate.c   **** //-------------------------------------
  39:heartrate.c   **** // MAIN BEAT DETECTOR
  40:heartrate.c   **** //-------------------------------------
  41:heartrate.c   **** bool checkForBeat(int32_t sample)
  42:heartrate.c   **** {
  43:heartrate.c   ****     bool beatDetected = false;
  44:heartrate.c   **** 
  45:heartrate.c   ****     // Save previous AC value
  46:heartrate.c   ****     IR_AC_Signal_Previous = IR_AC_Signal_Current;
  47:heartrate.c   **** 
  48:heartrate.c   ****     // DC estimation (fixed for MAX30102)
  49:heartrate.c   ****     IR_Average_Estimated = averageDCEstimator(&ir_avg_reg, sample);
  50:heartrate.c   **** 
  51:heartrate.c   ****     // AC component
  52:heartrate.c   ****     IR_AC_Signal_Current = lowPassFIRFilter(sample - IR_Average_Estimated);
  53:heartrate.c   **** 
  54:heartrate.c   ****     // Rising zero-crossing
  55:heartrate.c   ****     if ((IR_AC_Signal_Previous < 0) && (IR_AC_Signal_Current >= 0))
  56:heartrate.c   ****     {
  57:heartrate.c   ****         IR_AC_Max = IR_AC_Signal_max;
  58:heartrate.c   ****         IR_AC_Min = IR_AC_Signal_min;
  59:heartrate.c   **** 
  60:heartrate.c   ****         positiveEdge = 1;
  61:heartrate.c   ****         negativeEdge = 0;
  62:heartrate.c   **** 
  63:heartrate.c   ****         IR_AC_Signal_max = 0;
  64:heartrate.c   **** 
  65:heartrate.c   ****         // amplitude threshold tuned for MAX30102
  66:heartrate.c   ****         int16_t amplitude = IR_AC_Max - IR_AC_Min;
  67:heartrate.c   ****         if (amplitude > 50 && amplitude < 4000)
  68:heartrate.c   ****         {
  69:heartrate.c   ****             beatDetected = true;
  70:heartrate.c   ****         }
  71:heartrate.c   ****     }
  72:heartrate.c   **** 
  73:heartrate.c   ****     // Falling zero-crossing
  74:heartrate.c   ****     if ((IR_AC_Signal_Previous > 0) && (IR_AC_Signal_Current <= 0))
  75:heartrate.c   ****     {
  76:heartrate.c   ****         positiveEdge = 0;
  77:heartrate.c   ****         negativeEdge = 1;
  78:heartrate.c   ****         IR_AC_Signal_min = 0;
  79:heartrate.c   ****     }
  80:heartrate.c   **** 
  81:heartrate.c   ****     // Track max
  82:heartrate.c   ****     if (positiveEdge && (IR_AC_Signal_Current > IR_AC_Signal_Previous))
  83:heartrate.c   ****     {
  84:heartrate.c   ****         IR_AC_Signal_max = IR_AC_Signal_Current;
  85:heartrate.c   ****     }
  86:heartrate.c   **** 
  87:heartrate.c   ****     // Track min
ARM GAS  C:\Users\joshw\AppData\Local\Temp\ccsuHxsF.s 			page 3


  88:heartrate.c   ****     if (negativeEdge && (IR_AC_Signal_Current < IR_AC_Signal_Previous))
  89:heartrate.c   ****     {
  90:heartrate.c   ****         IR_AC_Signal_min = IR_AC_Signal_Current;
  91:heartrate.c   ****     }
  92:heartrate.c   **** 
  93:heartrate.c   ****     return beatDetected;
  94:heartrate.c   **** }
