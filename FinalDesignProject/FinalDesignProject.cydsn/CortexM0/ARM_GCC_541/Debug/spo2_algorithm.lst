  69:spo2_algorithm.c **** 
  70:spo2_algorithm.c ****   // calculates DC mean and subtract DC from ir
  71:spo2_algorithm.c ****   un_ir_mean = 0; 
  72:spo2_algorithm.c ****   for (k = 0; k < n_ir_buffer_length; k++) 
  73:spo2_algorithm.c ****     un_ir_mean += pun_ir_buffer[k];
  74:spo2_algorithm.c ****   un_ir_mean = un_ir_mean / n_ir_buffer_length;
  75:spo2_algorithm.c ****     
  76:spo2_algorithm.c ****   // remove DC and invert signal so that we can use peak detector as valley detector
  77:spo2_algorithm.c ****   for (k = 0; k < n_ir_buffer_length; k++)  
  78:spo2_algorithm.c ****     an_x[k] = -1 * (pun_ir_buffer[k] - un_ir_mean); 
  79:spo2_algorithm.c ****     
  80:spo2_algorithm.c ****   // 4 pt Moving Average
  81:spo2_algorithm.c ****   for(k = 0; k < BUFFER_SIZE - MA4_SIZE; k++){
  82:spo2_algorithm.c ****     an_x[k] = (an_x[k] + an_x[k+1] + an_x[k+2] + an_x[k+3]) / (int)4;        
  83:spo2_algorithm.c ****   }
  84:spo2_algorithm.c ****   
  85:spo2_algorithm.c ****   // calculate threshold  
  86:spo2_algorithm.c ****   n_th1 = 0; 
  87:spo2_algorithm.c ****   for (k = 0; k < BUFFER_SIZE; k++){
ARM GAS  C:\Users\joshw\AppData\Local\Temp\ccyVVHcx.s 			page 3


