  37:spo2_algorithm.c **** /**
  38:spo2_algorithm.c **** * \brief        Calculate the heart rate and SpO2 level
  39:spo2_algorithm.c **** * \par          Details
  40:spo2_algorithm.c **** *               By detecting peaks of PPG cycle and corresponding AC/DC of red/infra-red signal, th
  41:spo2_algorithm.c **** *               Since this algorithm is aiming for Arm M0/M3, formula for SPO2 did not achieve the 
  42:spo2_algorithm.c **** *               Thus, accurate SPO2 is precalculated and saved into uch_spo2_table[] per each ratio
  43:spo2_algorithm.c **** *
  44:spo2_algorithm.c **** * \param[in]    *pun_ir_buffer           - IR sensor data buffer
  45:spo2_algorithm.c **** * \param[in]    n_ir_buffer_length       - IR sensor data buffer length
  46:spo2_algorithm.c **** * \param[in]    *pun_red_buffer          - Red sensor data buffer
  47:spo2_algorithm.c **** * \param[out]   *pn_spo2                 - Calculated SpO2 value
  48:spo2_algorithm.c **** * \param[out]   *pch_spo2_valid          - 1 if the calculated SpO2 value is valid
  49:spo2_algorithm.c **** * \param[out]   *pn_heart_rate           - Calculated heart rate value
  50:spo2_algorithm.c **** * \param[out]   *pch_hr_valid            - 1 if the calculated heart rate value is valid
  51:spo2_algorithm.c **** *
  52:spo2_algorithm.c **** * \retval       None
  53:spo2_algorithm.c **** */
  54:spo2_algorithm.c **** {
