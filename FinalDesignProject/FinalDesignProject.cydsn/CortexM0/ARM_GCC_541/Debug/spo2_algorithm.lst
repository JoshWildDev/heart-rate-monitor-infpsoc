 231:spo2_algorithm.c **** void maxim_remove_close_peaks(int32_t *pn_locs, int32_t *pn_npks, int32_t *pn_x, int32_t n_min_dist
 232:spo2_algorithm.c **** /**
 233:spo2_algorithm.c **** * \brief        Remove peaks
ARM GAS  C:\Users\joshw\AppData\Local\Temp\ccyVVHcx.s 			page 8


 234:spo2_algorithm.c **** * \par          Details
 235:spo2_algorithm.c **** *               Remove peaks separated by less than MIN_DISTANCE
 236:spo2_algorithm.c **** *
 237:spo2_algorithm.c **** * \retval       None
 238:spo2_algorithm.c **** */
 239:spo2_algorithm.c **** {
 240:spo2_algorithm.c ****   int32_t i, j, n_old_npks, n_dist;
 241:spo2_algorithm.c ****     
 242:spo2_algorithm.c ****   /* Order peaks from large to small */
 243:spo2_algorithm.c ****   maxim_sort_indices_descend(pn_x, pn_locs, *pn_npks);
 244:spo2_algorithm.c **** 
 245:spo2_algorithm.c ****   for (i = -1; i < *pn_npks; i++){
 246:spo2_algorithm.c ****     n_old_npks = *pn_npks;
 247:spo2_algorithm.c ****     *pn_npks = i + 1;
 248:spo2_algorithm.c ****     for (j = i + 1; j < n_old_npks; j++){
 249:spo2_algorithm.c ****       n_dist = pn_locs[j] - (i == -1 ? -1 : pn_locs[i]); // lag-zero peak of autocorr is at index -
 250:spo2_algorithm.c ****       if (n_dist > n_min_distance || n_dist < -n_min_distance)
 251:spo2_algorithm.c ****         pn_locs[(*pn_npks)++] = pn_locs[j];
 252:spo2_algorithm.c ****     }
 253:spo2_algorithm.c ****   }
 254:spo2_algorithm.c **** 
 255:spo2_algorithm.c ****   // Resort indices into ascending order
 256:spo2_algorithm.c ****   maxim_sort_ascend(pn_locs, *pn_npks);
 257:spo2_algorithm.c **** }
