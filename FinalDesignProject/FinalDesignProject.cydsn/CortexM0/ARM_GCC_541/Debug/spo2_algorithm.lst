 119:spo2_algorithm.c ****   n_exact_ir_valley_locs_count = n_npks; 
 120:spo2_algorithm.c ****   
 121:spo2_algorithm.c ****   // using exact_ir_valley_locs, find ir-red DC and ir-red AC for SPO2 calibration ratio
 122:spo2_algorithm.c ****   // finding AC/DC maximum of raw
 123:spo2_algorithm.c ****   n_ratio_average = 0; 
 124:spo2_algorithm.c ****   n_i_ratio_count = 0; 
