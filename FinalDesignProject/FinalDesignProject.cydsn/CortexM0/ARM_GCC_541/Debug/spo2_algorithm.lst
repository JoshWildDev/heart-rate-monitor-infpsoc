  91:spo2_algorithm.c ****   if(n_th1 < 30) n_th1 = 30; // min allowed
  92:spo2_algorithm.c ****   if(n_th1 > 60) n_th1 = 60; // max allowed
  93:spo2_algorithm.c **** 
  94:spo2_algorithm.c ****   for (k = 0; k < 15; k++) an_ir_valley_locs[k] = 0;
  95:spo2_algorithm.c ****   
