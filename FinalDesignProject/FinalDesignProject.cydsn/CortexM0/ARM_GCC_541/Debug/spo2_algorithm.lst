 134:spo2_algorithm.c ****   
 135:spo2_algorithm.c ****   // find max between two valley locations 
 136:spo2_algorithm.c ****   // and use ratio between AC component of IR & Red and DC component of IR & Red for SPO2 
 137:spo2_algorithm.c ****   for (k = 0; k < n_exact_ir_valley_locs_count - 1; k++){
