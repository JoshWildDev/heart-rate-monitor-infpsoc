  53:spo2_algorithm.c ****     // DC mean
  54:spo2_algorithm.c ****     un_ir_mean = 0; 
  55:spo2_algorithm.c ****     for (k = 0; k < n_ir_buffer_length; k++) 
  56:spo2_algorithm.c ****         un_ir_mean += pun_ir_buffer[k];
  57:spo2_algorithm.c ****     un_ir_mean /= n_ir_buffer_length;
  58:spo2_algorithm.c ****     
  59:spo2_algorithm.c ****     // Remove DC, invert
  60:spo2_algorithm.c ****     for (k = 0; k < n_ir_buffer_length; k++)  
  61:spo2_algorithm.c ****         an_x[k] = -1 * (pun_ir_buffer[k] - un_ir_mean); 
  62:spo2_algorithm.c ****     
  63:spo2_algorithm.c ****     // 4-pt moving average
  64:spo2_algorithm.c ****     for(k = 0; k < BUFFER_SIZE - MA4_SIZE; k++){
  65:spo2_algorithm.c ****         an_x[k] = (an_x[k] + an_x[k+1] + an_x[k+2] + an_x[k+3]) / 4;        
  66:spo2_algorithm.c ****     }
  67:spo2_algorithm.c ****     
  68:spo2_algorithm.c ****     // Threshold
  69:spo2_algorithm.c ****     n_th1 = 0; 
  70:spo2_algorithm.c ****     for (k = 0; k < BUFFER_SIZE; k++) n_th1 += an_x[k];
  71:spo2_algorithm.c ****     n_th1 /= BUFFER_SIZE;
  72:spo2_algorithm.c ****     if(n_th1 < 30) n_th1 = 30;
  73:spo2_algorithm.c ****     if(n_th1 > 60) n_th1 = 60;
  74:spo2_algorithm.c **** 
  75:spo2_algorithm.c ****     for (k = 0; k < 15; k++) an_ir_valley_locs[k] = 0;
  76:spo2_algorithm.c ****     
  77:spo2_algorithm.c ****     // Peak detection, increase min_distance to 20 samples (~400 ms at 50 Hz)
  78:spo2_algorithm.c ****     maxim_find_peaks(an_ir_valley_locs, &n_npks, an_x, BUFFER_SIZE, n_th1, 20, 15); 
  79:spo2_algorithm.c ****     
  80:spo2_algorithm.c ****     // Heart rate calculation
  81:spo2_algorithm.c ****     n_peak_interval_sum = 0;
  82:spo2_algorithm.c ****     if (n_npks >= 2){
  83:spo2_algorithm.c ****         for (k = 1; k < n_npks; k++) 
  84:spo2_algorithm.c ****             n_peak_interval_sum += (an_ir_valley_locs[k] - an_ir_valley_locs[k-1]);
  85:spo2_algorithm.c ****         n_peak_interval_sum /= (n_npks - 1);
  86:spo2_algorithm.c **** 
  87:spo2_algorithm.c ****         int32_t hr = (int32_t)((FreqS * 60) / n_peak_interval_sum);
